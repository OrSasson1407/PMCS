# ── PMCS Production Environment Variables ────────────────────────────────────
# Copy this file to .env.production and fill in real values
# NEVER commit .env.production to git

# PostgreSQL
POSTGRES_PASSWORD=change_me_strong_password_here

# Redis
REDIS_PASSWORD=change_me_redis_password_here

# JWT
JWT_SECRET=change_me_minimum_32_chars_secret_here

# GitHub Webhook
GITHUB_WEBHOOK_SECRET=change_me_github_webhook_secret_here
